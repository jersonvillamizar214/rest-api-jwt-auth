// Prisma schema — https://www.prisma.io/docs
generator client {
  provider = "prisma-client-js"
  // "native" for local dev; the rhel target is the engine Vercel's serverless
  // runtime (Amazon Linux / RHEL, OpenSSL 3) needs at runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String // bcrypt hash — never the plaintext
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]

  @@map("users")
}

// Persisted refresh tokens allow server-side revocation (logout / rotation).
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

enum Role {
  USER
  ADMIN
}
